---
import '../styles/global.css';
import App from '../components/App';
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO Meta Tags -->
		<title>RonnakritNet | Computer Engineering & Network Automation Portfolio</title>
		<meta name="description" content="Official portfolio of Ronnakrit Wananukan. A Computer Engineering student passionate about Network Engineering, Automation, and Linux. Currently preparing for CCNA and documenting technical projects." />
		<meta name="keywords" content="Ronnakrit, Computer Engineering, Network Engineer, Portfolio, CLI, Terminal, Network Automation, Python, Cisco, MikroTik, CCNA, Linux" />
		<meta name="author" content="Ronnakrit Wananukan" />
		
		<!-- Open Graph Meta Tags -->
		<meta property="og:title" content="RonnakritNet | Computer Engineering & Network Automation Portfolio" />
		<meta property="og:description" content="Official portfolio of Ronnakrit Wananukan. A Computer Engineering student passionate about Network Engineering, Automation, and Linux. Currently preparing for CCNA and documenting technical projects." />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://ronnakrit.net" />
		<meta property="og:image" content="https://ronnakrit.net/og-preview.png" />
		<meta property="og:image:alt" content="RonnakritNet | Computer Engineering & Network Automation Portfolio" />
		<meta property="og:site_name" content="RonnakritNet" />
		
		<!-- Twitter Card Meta Tags -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="RonnakritNet | Computer Engineering & Network Automation Portfolio" />
		<meta name="twitter:description" content="Official portfolio of Ronnakrit Wananukan. A Computer Engineering student passionate about Network Engineering, Automation, and Linux. Currently preparing for CCNA and documenting technical projects." />
		<meta name="twitter:image" content="https://ronnakrit.net/og-preview.png" />
		<meta name="twitter:image:alt" content="RonnakritNet | Computer Engineering & Network Automation Portfolio" />
		
		<!-- LinkedIn Meta Tags -->
		<meta property="linkedin:owner" content="ronnakrit" />
		<meta property="linkedin:company" content="ronnakrit.net" />
		
		<!-- Additional SEO -->
		<meta name="robots" content="index, follow" />
		<meta name="language" content="English" />
		<meta name="theme-color" content="#0D0D0D" />
		
		<!-- Structured Data -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "Ronnakrit Wananukan",
			"jobTitle": "Computer Engineering Student",
			"description": "Official portfolio of Ronnakrit Wananukan. A Computer Engineering student passionate about Network Engineering, Automation, and Linux. Currently preparing for CCNA and documenting technical projects.",
			"url": "https://ronnakrit.net",
			"email": "contact@ronnakrit.net",
			"knowsAbout": ["Network Engineering", "Computer Engineering", "Python", "Cisco", "MikroTik", "Linux", "System Administration", "Full-stack Development", "CCNA", "Network Automation"],
			"sameAs": [
				"https://github.com/ronnakrit",
				"https://linkedin.com/in/ronnakrit"
			]
		}
		</script>
	</head>
	<body>
		<div id="app">
			<App client:load />
		</div>
	</body>
</html>
